  <property name="styleSheet">
   <string notr="true">/* 第四頁表格樣式 */
QTableWidget#tableTimeMatrix {
    background-color: #050505;
    gridline-color: #222222; /* 網格線顏色 */
    border: 1px solid #333333;
    border-radius: 8px;
}

/* 表格標題 (日期與時間列) */
QHeaderView::section {
    background-color: #0d0d0d;
    color: #888888;
    padding: 8px;
    border: 1px solid #222222;
    font-size: 12px;
}

/* 分頁按鈕基礎樣式 */
QPushButton#btnYourTime, QPushButton#btnGroupTime {
    background-color: #121212;
    color: #888888;
    border: 1px solid #333333;
    border-radius: 4px;
    padding: 10px;
    font-weight: bold;
}

/* 當 Your Time 被選中時 (白底黑字) */
QPushButton#btnYourTime {
    background-color: #FFFFFF;
    color: #000000;
}

/* 確認送出按鈕 (亮綠色) */
QPushButton#btnSubmitTime {
    background-color: #2ECC71;
    color: white;
    border-radius: 6px;
    font-weight: bold;
    min-height: 40px;
}</string>
  </property>
  <widget class="QWidget" name="centralwidget">
   <layout class="QVBoxLayout" name="verticalLayout_5">
    <item>
     <widget class="QStackedWidget" name="stackedWidget">
      <property name="styleSheet">
       <string notr="true">/* 月曆全體深色化 */
QCalendarWidget QWidget {
    background-color: #050505;
}

/* 月曆上方的導覽列 (月份/年份) */
QCalendarWidget QToolButton {
    color: white;
    background-color: #121212;
    border-radius: 4px;
}

/* 星期幾與日期 */
QCalendarWidget QAbstractItemView:enabled {
    color: #FFFFFF;
    selection-background-color: #FFFFFF; /* 選中的日期變白底 */
    selection-color: #000000;            /* 字變黑 */
}

/* 網格線顏色 */
QCalendarWidget {
    border: 1px solid #333333;
}</string>
